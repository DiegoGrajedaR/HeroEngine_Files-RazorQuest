@page
@model VideoGameManager.Pages.Developers.DeleteModel
@{
}

<h1>Delete Developer</h1>

<h3 class="text-danger">Are you sure you want to delete this Developer?</h3>

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<div>
    <h4>Developer Details</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Developer.Name)</dt>
        <dd class="col-sm-9">@Model.Developer.Name</dd>

        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Developer.Country)</dt>
        <dd class="col-sm-9">@Model.Developer.Country</dd>

        <dt class="col-sm-3">Games Count</dt>
        <dd class="col-sm-9">
            <span class="badge bg-info text-dark">@Model.Developer.Games?.Count</span>
        </dd>
    </dl>

    @if (Model.Developer.Games != null && Model.Developer.Games.Any())
    {
        <div class="alert alert-warning">
            <h5>Associated Games:</h5>
            <ul>
                @foreach (var game in Model.Developer.Games)
                {
                    <li>@game.Title (@game.Year)</li>
                }
            </ul>
        </div>
    }

    <form method="post">
        <input type="hidden" asp-for="Developer.Id" />
        
        @if (Model.Developer.Games != null && Model.Developer.Games.Any())
        {
            <button type="submit" class="btn btn-danger" disabled>Delete</button>
            <p class="text-muted mt-2"><em>The delete button is disabled because there are associated games.</em></p>
        }
        else
        {
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
        }
        
        <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>