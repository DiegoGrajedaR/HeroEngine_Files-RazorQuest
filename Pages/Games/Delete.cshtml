@page
@model VideoGameManager.Pages.Games.DeleteModel
@{
}

<h1>Delete Game</h1>

<h3 class="text-danger">Are you sure you want to delete this game?</h3>

<div>
    <h4>Game Configuration</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Game.Title</dd>

        <dt class="col-sm-2">Genre</dt>
        <dd class="col-sm-10">@Model.Game.Genre</dd>

        <dt class="col-sm-2">Year</dt>
        <dd class="col-sm-10">@Model.Game.Year</dd>

        <dt class="col-sm-2">Score</dt>
        <dd class="col-sm-10">@Model.Game.Score</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Game.Description</dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="Game.Id" />
        
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-page="./Index" class="btn btn-secondary">Cancel and Back to List</a>
    </form>
</div>