@page
@model VideoGameManager.Pages.Games.IndexModel
@{

}

<h1>Games List</h1>

<p>
    <a asp-page="Create" class="btn btn-primary">Create New Game</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Genre</th>
            <th>Year</th>
            <th>Score</th>
            <th>Developer</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var game in Model.GamesList)
        {
            <tr>
                <td>@game.Title</td>
                <td>@game.Genre</td>
                <td>@game.Year</td>
                <td>@game.Score</td>
                <td>@game.Developer?.Name</td>
                <td>
                    <a asp-page="Details" asp-route-id="@game.Id" class="btn btn-info btn-sm">Details</a>
                    <a asp-page="Edit" asp-route-id="@game.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-page="Delete" asp-route-id="@game.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>